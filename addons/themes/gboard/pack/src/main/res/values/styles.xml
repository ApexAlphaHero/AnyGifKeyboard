<?xml version="1.0" encoding="utf-8"?>
<!-- Gboard-inspired dark theme for AnySoftKeyboard.

     Colours mirror the Material dark Gboard look:
       background     #202124  (near-black slate)
       letter keys    #2A2D2F  (slightly raised, rounded)
       function keys   #3A3E42  (lighter blue-grey: shift, backspace, ?123, enter, ...)
       text           #E8EAED  (off-white)
       hint text      #9AA0A6  (muted grey)
-->
<resources>
    <style name="GboardAnyKeyboardTheme">
        <item name="android:background">@drawable/gboard_background</item>
        <item name="keyBackground">@drawable/btn_keyboard_key_gboard</item>

        <item name="keyTextSize">@dimen/key_text_size</item>
        <item name="keyTextStyle">normal</item>
        <item name="keyTextColor">#FFE8EAED</item>
        <item name="hintTextColor">#FF9AA0A6</item>
        <item name="labelTextSize">@dimen/key_label_text_size</item>

        <!-- flat material look: no text shadow -->
        <item name="shadowColor">#00000000</item>
        <item name="shadowRadius">0px</item>
        <item name="shadowOffsetX">0px</item>
        <item name="shadowOffsetY">0px</item>
        <item name="backgroundDimAmount">0.5</item>

        <!-- key preview (the magnified pop-up shown while typing letters) -->
        <item name="keyPreviewBackground">@drawable/key_preview_background</item>
        <item name="keyPreviewTextColor">#FFE8EAED</item>
        <item name="keyPreviewTextSize">32sp</item>
        <item name="keyPreviewLabelTextSize">22sp</item>

        <!-- key heights -->
        <item name="keyNormalHeight">@dimen/default_key_height</item>
        <item name="keySmallHeight">@dimen/default_key_half_height</item>
        <item name="keyLargeHeight">@dimen/default_key_tall_height</item>

        <!-- key gaps -->
        <item name="keyHorizontalGap">@dimen/default_key_horizontal_gap</item>
        <item name="keyVerticalGap">@dimen/default_key_vertical_gap</item>
    </style>

    <style name="GboardAnyKeyboardPopupTheme" parent="@style/GboardAnyKeyboardTheme">
        <item name="android:background">@drawable/popup_background</item>
        <item name="keyBackground">@drawable/btn_keyboard_key_popup_gboard</item>
        <!-- no nested preview inside the pop-up -->
        <item name="keyPreviewTextSize">0px</item>
    </style>
</resources>
