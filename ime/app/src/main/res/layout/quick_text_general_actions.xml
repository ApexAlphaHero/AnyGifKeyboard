<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom action strip for the emoji/quick-text panel (Gboard style). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/quick_text_actions_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/quick_keys_popup_close"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="44dp"
        android:background="?android:attr/selectableItemBackground"
        android:contentDescription="@string/close_button"
        android:scaleType="centerInside"
        android:src="@drawable/sym_keyboard_cancel" />

    <ImageView
        android:id="@+id/quick_keys_popup_quick_keys_insert_media"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="44dp"
        android:background="?android:attr/selectableItemBackground"
        android:scaleType="centerInside"
        android:src="@drawable/ic_media_insertion" />

    <ImageView
        android:id="@+id/quick_keys_popup_delete_recently_used_smileys"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="44dp"
        android:background="?android:attr/selectableItemBackground"
        android:scaleType="centerInside"
        android:src="@drawable/ic_delete_forever_dark" />

    <ImageView
        android:id="@+id/quick_keys_popup_quick_keys_settings"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="44dp"
        android:background="?android:attr/selectableItemBackground"
        android:contentDescription="@string/quick_text_keys_group"
        android:scaleType="centerInside"
        android:src="@drawable/ic_action_settings" />

    <ImageView
        android:id="@+id/quick_keys_popup_backspace"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="44dp"
        android:background="?android:attr/selectableItemBackground"
        android:scaleType="centerInside"
        android:src="@drawable/sym_keyboard_delete" />

</LinearLayout>
