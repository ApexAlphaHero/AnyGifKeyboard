<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/gif_source_edit_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/gif_source_label_hint"
            android:importantForAutofill="no"
            android:inputType="text"
            android:maxLines="1" />

        <RadioGroup
            android:id="@+id/gif_source_edit_type_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/gif_source_type_giphery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gif_source_type_giphery" />

            <RadioButton
                android:id="@+id/gif_source_type_giphy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/gif_source_type_giphy" />
        </RadioGroup>

        <LinearLayout
            android:id="@+id/gif_source_edit_giphery_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/gif_source_edit_base_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/gif_source_base_url_hint"
                android:importantForAutofill="no"
                android:inputType="textUri"
                android:maxLines="1" />

            <EditText
                android:id="@+id/gif_source_edit_access_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/gif_source_access_token_hint"
                android:importantForAutofill="no"
                android:inputType="text"
                android:maxLines="1" />

            <EditText
                android:id="@+id/gif_source_edit_refresh_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/gif_source_refresh_token_hint"
                android:importantForAutofill="no"
                android:inputType="text"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/gif_source_edit_giphy_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/gif_source_edit_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/gif_source_api_key_hint"
                android:importantForAutofill="no"
                android:inputType="text"
                android:maxLines="1" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:text="@string/gif_source_api_key_help"
                android:textAppearance="?android:attr/textAppearanceSmall" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
